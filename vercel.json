{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/italian-builders run build",
  "outputDirectory": "artifacts/italian-builders/dist/public",
  "rewrites": [
    {
      "source": "/api/admin/waitlist/activate",
      "destination": "/api/admin/waitlist/action?action=activate"
    },
    {
      "source": "/api/admin/waitlist/activate-batch",
      "destination": "/api/admin/waitlist/action?action=activate-batch"
    },
    {
      "source": "/api/admin/waitlist/:id/activate",
      "destination": "/api/admin/waitlist/action?action=activate&id=:id"
    },
    {
      "source": "/api/admin/content/preview",
      "destination": "/api/admin/waitlist/action?action=content-preview"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/builders/:username",
      "destination": "/api/builder-profile?username=:username"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
