# Italian Builders Hub environment template
# Copy this file to .env.local or .env, then replace the placeholder values.
# Do not put real secrets in this .env.example file.

# -----------------------------------------------------------------------------
# Local runtime
# -----------------------------------------------------------------------------

# Local port for the Express API server when running:
# pnpm --filter @workspace/api-server run dev
PORT=5000

# Base path for the Vite app. Keep "/" for root deployments.
BASE_PATH=/

# Logging level for the API server. Common values: trace, debug, info, warn, error.
LOG_LEVEL=info

# Public URL of the deployed application. Used for auth redirects, invite links,
# canonical URLs, and server-generated absolute links.
APP_BASE_URL=https://your-domain.com

# Browser-safe version of APP_BASE_URL for auth redirect URLs in the Vite app.
VITE_APP_BASE_URL=https://your-domain.com

# Allowed browser origin for API requests. For production, use APP_BASE_URL.
# For local development, use your Vite dev URL, for example http://localhost:5173.
CORS_ORIGIN=https://your-domain.com

# Comma-separated admin emails. These users can access internal/admin actions.
ADMIN_EMAILS=domenico.dd@gmail.com

# -----------------------------------------------------------------------------
# Supabase public client values
# These values are safe to expose to the browser and may be used by Vite.
# -----------------------------------------------------------------------------

# Supabase project URL from Project Settings > API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable or anon key from Project Settings > API.
# This is browser-safe, but database access must still be protected by RLS.
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Public Supabase Storage bucket used by the browser for uploaded profile and
# project media. This can later be migrated behind Cloudflare R2/CDN.
VITE_SUPABASE_MEDIA_BUCKET=italian-builders-media

# -----------------------------------------------------------------------------
# Supabase server-only values
# Never expose these through VITE_* variables or frontend code.
# -----------------------------------------------------------------------------

# Same Supabase project URL, used by server-side code.
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key for server-side admin actions, such as inviting users.
# Keep private. This bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Direct Postgres connection string for server-side DB access and migrations.
# Supabase pooler format is usually the most reliable from local/Vercel:
# postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase project reference, the short ID in your project URL:
# https://<project-ref>.supabase.co
SUPABASE_PROJECT_REF=your-project-ref

# Personal access token for Supabase CLI/API automation, if you want me to apply
# migrations or inspect the project from this workspace.
SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# -----------------------------------------------------------------------------
# Cloudflare R2 storage
# Used for profile avatars, project images, and other public media.
# -----------------------------------------------------------------------------

# Cloudflare API token for one-time setup/automation: creating the bucket,
# configuring CORS, and optionally connecting a custom domain.
# Recommended permissions: R2 Admin Read & Write for the target account.
# Add DNS edit permission too only if you want automation to connect a custom
# asset domain in a Cloudflare-managed zone.
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Optional Cloudflare zone ID for the domain that will serve public assets.
# Needed only if you want me to wire a custom R2 domain such as assets.example.com.
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# Cloudflare account ID, visible in the Cloudflare dashboard URL/sidebar.
R2_ACCOUNT_ID=your-cloudflare-account-id

# R2 bucket name for this project.
R2_BUCKET_NAME=italian-builders-hub

# Optional R2 location hint. Leave empty unless you specifically want a regional
# bucket. Example: EU. Jurisdictional buckets require jurisdiction-specific
# endpoints, so default/global is simpler unless you have a data-residency need.
R2_LOCATION_HINT=

# S3-compatible R2 access key ID.
R2_ACCESS_KEY_ID=your-r2-access-key-id

# S3-compatible R2 secret access key. Keep private.
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# S3-compatible endpoint for the account.
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com

# Public base URL for reading stored assets. Use a custom domain if configured,
# otherwise use the public R2/dev URL you choose for the bucket.
R2_PUBLIC_BASE_URL=https://assets.your-domain.com

# Browser-safe copy of the public asset base URL for the Vite app.
VITE_R2_PUBLIC_BASE_URL=https://assets.your-domain.com

# Optional custom domain to connect to the bucket for production public assets.
# Recommended for production instead of r2.dev.
R2_CUSTOM_DOMAIN=assets.your-domain.com

# -----------------------------------------------------------------------------
# Optional invite email
# -----------------------------------------------------------------------------

# If configured later, server-side invite creation can email invite links.
# The current MVP works without email by letting admins copy invite links.
RESEND_API_KEY=your-resend-api-key
INVITE_FROM_EMAIL=Italian Builders <invites@your-domain.com>

# -----------------------------------------------------------------------------
# Vercel deployment automation
# Optional, but useful if you want this workspace to deploy/configure the project.
# -----------------------------------------------------------------------------

# Vercel API token from Account Settings > Tokens.
VERCEL_TOKEN=your-vercel-token

# Vercel team/user ID. Usually created by running `vercel link` or visible in
# .vercel/project.json after linking.
VERCEL_ORG_ID=your-vercel-org-id

# Vercel project ID. Usually created by running `vercel link` or visible in
# .vercel/project.json after linking.
VERCEL_PROJECT_ID=your-vercel-project-id
